# --- Copia este archivo a .env y ajusta lo que necesites. Todo es opcional en local. ---

# General
APP_NAME=Algorise
ENVIRONMENT=local
DEBUG=true

# Base de datos
# Local (por defecto, 100% en este ordenador):
DATABASE_URL=sqlite:///./algorise.db
# Para nube/Supabase (Postgres), descomenta y rellena:
# DATABASE_URL=postgresql+psycopg://USUARIO:CONTRASENA@HOST:5432/postgres

# Seguridad (CAMBIA SECRET_KEY si lo despliegas en internet)
SECRET_KEY=dev-insecure-change-me-in-production
DEFAULT_USERNAME=admin
DEFAULT_PASSWORD=admin

# CORS (orígenes del frontend; * para desarrollo local)
CORS_ORIGINS=*

# Exchange (Binance). Déjalo vacío para paper trading con datos públicos.
EXCHANGE_ID=binance
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=

# IA / LLM (gratis). Configura según el proveedor que uses desde la UI.
OLLAMA_BASE_URL=http://localhost:11434
GROQ_API_KEY=
GEMINI_API_KEY=
